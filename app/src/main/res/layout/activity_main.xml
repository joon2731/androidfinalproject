<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F0F0"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomMenuLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/bottomMenuLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#F5F5F5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <Button android:id="@+id/btn_a1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="a1" />
        <Button android:id="@+id/btn_a2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="a2" android:layout_marginHorizontal="8dp" />
        <Button android:id="@+id/btn_settings" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="설정" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>